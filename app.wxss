page {
  min-height: 100%;
  background: #fff6f2;
  color: #2f2a2c;
  font-family: "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
}

.card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  box-shadow: 0 16rpx 48rpx rgba(255, 107, 129, 0.08);
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2d1f28;
}

.section-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #9d838e;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff7f95, #ff5d73);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 14rpx 24rpx rgba(255, 93, 115, 0.22);
}

.primary-button::after {
  border: none;
}

.tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff0f4;
  color: #ff5d73;
  font-size: 22rpx;
  line-height: 1;
}
