.page {
  padding: 24rpx 24rpx 32rpx;
}

.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 18rpx 4rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #2f2027;
}

.hero-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #967d86;
}

.locate-button {
  padding: 0 30rpx;
  height: 72rpx;
  line-height: 72rpx;
  border: none;
  border-radius: 999rpx;
  background: #fff;
  color: #ff6278;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 24rpx rgba(255, 98, 120, 0.12);
}

.locate-button::after {
  border: none;
}

.map-card {
  overflow: hidden;
  border-radius: 36rpx;
}

.map {
  width: 100%;
  height: 720rpx;
}

.sheet {
  margin-top: 24rpx;
  padding: 28rpx 24rpx;
}

.sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.count-badge {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #fff1f5;
  color: #ff6278;
  font-size: 22rpx;
  font-weight: 600;
}

.location-item {
  display: flex;
  margin-bottom: 20rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #fff8fb;
}

.location-item:last-child {
  margin-bottom: 0;
}

.location-cover {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  border-radius: 20rpx;
  background: #f2e5ea;
}

.location-main {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.location-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.location-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #2f2027;
}

.location-distance {
  font-size: 22rpx;
  color: #ff6278;
}

.location-address {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8f7782;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}
