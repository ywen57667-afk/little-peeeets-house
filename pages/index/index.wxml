<view class="page">
  <view class="hero">
    <view>
      <view class="hero-title">重庆狗狗地图</view>
      <view class="hero-desc">发现可带狗散步、晒太阳、社交的友好地点</view>
    </view>
    <button class="locate-button" bindtap="moveToUserLocation">定位我</button>
  </view>

  <view class="map-card card">
    <map
      id="dog-map"
      class="map"
      latitude="{{latitude}}"
      longitude="{{longitude}}"
      scale="{{scale}}"
      markers="{{markers}}"
      show-location
      enable-3D
      enable-zoom
      enable-rotate="false"
      bindmarkertap="handleMarkerTap"
    ></map>
  </view>

  <view class="sheet card">
    <view class="sheet-header">
      <view>
        <view class="section-title">精选遛狗点位</view>
        <view class="section-subtitle">本地 JSON + 用户发布内容</view>
      </view>
      <view class="count-badge">{{locations.length}}个地点</view>
    </view>

    <block wx:for="{{locations}}" wx:key="id">
      <view class="location-item" data-id="{{item.id}}" bindtap="openDetail">
        <image class="location-cover" src="{{item.cover}}" mode="aspectFill"></image>
        <view class="location-main">
          <view class="location-top">
            <text class="location-name">{{item.name}}</text>
            <text class="location-distance">地图查看</text>
          </view>
          <view class="location-address">{{item.address}}</view>
          <view class="tag-row">
            <text class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
          </view>
        </view>
      </view>
    </block>
  </view>
</view>
