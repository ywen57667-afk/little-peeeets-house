.publish-page {
  padding-top: 24rpx;
}

.publish-header {
  margin-bottom: 24rpx;
}

.form-card {
  padding: 28rpx 24rpx 32rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #33252d;
}

.input {
  width: 100%;
  height: 92rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #fff8fb;
  font-size: 28rpx;
  color: #2f2027;
}

.hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #a08691;
}

.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 84rpx;
  border: 2rpx solid #ffd3dc;
  border-radius: 22rpx;
  background: #fff;
  color: #ff5d73;
  font-size: 28rpx;
  font-weight: 600;
}

.ghost-button::after {
  border: none;
}

.location-preview {
  margin-top: 16rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #fff8fb;
}

.preview-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #31242b;
}

.preview-coord {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #977f89;
}

.preview-image {
  width: 100%;
  height: 360rpx;
  margin-top: 16rpx;
  border-radius: 24rpx;
  background: #f7e8ec;
}

.submit-button {
  margin-top: 12rpx;
}
